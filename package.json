{
  "name": "scribbles",
  "version": "2.0.0",
  "description": "Scribbles is a log and tracing lib for Node.js and Bun with automatic variable-name extraction, distributed tracing, and structured output",
  "files": [
    "dist/",
    "src/",
    "index.js",
    "index.mjs",
    "appDir.js",
    "register.mjs",
    "register.cjs",
    "gitStatus.js",
    "index.d.ts",
    "index.d.mts",
    "LICENSE"
  ],
  "main": "./dist/scribbles.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./dist/scribbles.js"
      },
      "default": "./dist/scribbles.js"
    },
    "./register": {
      "import": "./register.mjs",
      "require": "./register.cjs",
      "default": "./register.mjs"
    },
    "./gitStatus": "./gitStatus.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "rm -rf .git/hooks/* && cp -R .hooks/* .git/hooks/ && chmod +x .git/hooks/* .git/hooks/pre-commit.d/* 2>/dev/null || true",
    "build": "npx esbuild index.js --bundle --sourcemap --platform=node --external:../../package.json --outfile=dist/scribbles.js",
    "pretest": "npm run build",
    "test": "jest --no-cache",
    "test:watch": "jest --watch --runInBand",
    "test:cover": "jest --coverage --no-cache --detectOpenHandles",
    "test:subprocess": "nyc --silent node __tests__/subprocess/run-all.js",
    "test:full-coverage": "jest --coverage --no-cache && npm run test:subprocess && nyc report --reporter=text",
    "release": "bash scripts/publish.sh",
    "prepublishOnly": "npx esbuild index.js --bundle --minify --sourcemap --platform=node --external:../../package.json --outfile=dist/scribbles.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemeasandwich/scribbles.git"
  },
  "author": "Brian Shannon (https://github.com/codemeasandwich)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/codemeasandwich/scribbles/issues"
  },
  "keywords": [
    "trace",
    "trace context",
    "logging",
    "nodejs"
  ],
  "homepage": "https://github.com/codemeasandwich/scribbles#readme",
  "devDependencies": {
    "@ashleyw/cls-hooked": "^5.0.1",
    "jest": "^29.3.1",
    "moment": "^2.24.0",
    "nyc": "^17.1.0",
    "source-map-support": "^0.5.21",
    "string-template": "^1.0.0"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/fixtures/",
      "/__tests__/subprocess/",
      "/__tests__/scenarios/fixtures/",
      "/__tests__/scenarios/harness/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/",
      "/dist/",
      "/coverage/",
      "/docs/",
      "/scripts/",
      "\\.stub\\.js$"
    ]
  },
  "nyc": {
    "include": [
      "index.js",
      "src/**/*.js"
    ],
    "exclude": [
      "__tests__/**",
      "dist/**"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "report-dir": ".nyc_output"
  }
}
